#!/usr/bin/env bash

set -euo pipefail

readonly REPOSITORY="soyona/SAPDP"
readonly EXPECTED_ORIGIN="https://github.com/soyona/SAPDP"

fail() {
  printf 'sapdp-materialize: %s\n' "$1" >&2
  exit 1
}

[[ $# -eq 4 && $1 == --freeze-file && $3 == --expected-freeze-digest ]] \
  || fail 'usage: sapdp-materialize --freeze-file <path> --expected-freeze-digest sha256:<digest>'

freeze_file=$2
expected_freeze_digest=$4

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || fail 'not inside a Git repository'
cd "$repo_root"

# shellcheck source=scripts/lib/sapdp-validation.sh
source scripts/lib/sapdp-validation.sh

[[ $(git config --get remote.origin.url) == "$EXPECTED_ORIGIN" ]] || fail 'unexpected origin URL'
[[ $(git branch --show-current) == main ]] || fail 'current branch is not main'
git diff --check || fail 'git diff check failed'
sapdp_validate_freeze "$freeze_file" "$expected_freeze_digest" || fail 'invalid Design Freeze'

base_commit=$(sapdp_freeze_value "$freeze_file" base_commit_sha)
target_version=$(sapdp_freeze_value "$freeze_file" target_version)
commit_message=$(sapdp_freeze_value "$freeze_file" commit_message)
frozen_paths=$(mktemp)
actual_paths=$(mktemp)
trap 'rm -f "$frozen_paths" "$actual_paths"' EXIT
sapdp_freeze_values "$freeze_file" frozen_file >"$frozen_paths"

[[ $(sapdp_heading_version) == "$target_version" ]] || fail 'SAPDP version does not match Target Version'
git cat-file -e "${base_commit}^{commit}" 2>/dev/null || fail 'Base Commit is unavailable'

remote_main=$(git ls-remote origin refs/heads/main | awk '{print $1}')
[[ -n $remote_main ]] || fail 'remote main is unavailable'

if [[ -z $(git status --porcelain) ]]; then
  head=$(git rev-parse HEAD)
  parent=$(git rev-parse "${head}^" 2>/dev/null || true)
  if [[ $head == "$base_commit" ]]; then
    fail 'no file changes'
  fi
  [[ $parent == "$base_commit" ]] || fail 'clean HEAD is not a resumable candidate'
  sapdp_commit_paths "$base_commit" "$head" >"$actual_paths"
  cmp -s "$frozen_paths" "$actual_paths" || fail 'candidate paths do not match Frozen Files'
  sapdp_validate_authority || fail 'Authority Digest or Registry is invalid'
  ./scripts/sapdp-validate >/dev/null || fail 'protocol validation failed'

  if [[ $remote_main == "$base_commit" ]]; then
    git push --quiet origin HEAD:refs/heads/main
  elif [[ $remote_main != "$head" ]]; then
    fail 'remote main drifted from Base Commit and candidate'
  fi

  printf 'https://github.com/%s/commit/%s\n' "$REPOSITORY" "$head"
  exit 0
fi

[[ $(git rev-parse HEAD) == "$base_commit" ]] || fail 'HEAD does not match Base Commit'
[[ $remote_main == "$base_commit" ]] || fail 'remote main does not match Base Commit'
[[ -z $(git diff --name-only --diff-filter=U) ]] || fail 'repository has unresolved conflicts'
git push --dry-run --quiet origin HEAD:refs/heads/main \
  || fail 'remote push authentication or authorization failed'

calculated_digest=$(sapdp_authority_digest) || fail 'cannot calculate Authority Digest'
SAPDP_TMP=$(mktemp)
trap 'rm -f "$frozen_paths" "$actual_paths" "$SAPDP_TMP"' EXIT
awk -v digest="$calculated_digest" '
  /^Authority Digest:/ { print "Authority Digest: sha256:" digest; next }
  { print }
' SAPDP.md >"$SAPDP_TMP"
cmp -s SAPDP.md "$SAPDP_TMP" || cp "$SAPDP_TMP" SAPDP.md

sapdp_changed_paths >"$actual_paths"
cmp -s "$frozen_paths" "$actual_paths" || fail 'working tree paths do not match Frozen Files'

sapdp_validate_authority || fail 'Authority Digest or Registry is invalid'
./scripts/sapdp-validate >/dev/null || fail 'protocol validation failed'

while IFS= read -r path; do
  git add -- "$path"
done <"$frozen_paths"

git diff --cached --check || fail 'staged diff check failed'
git diff --cached --quiet && fail 'no staged changes'
git commit --quiet -m "$commit_message"
candidate=$(git rev-parse HEAD)

git push --quiet origin HEAD:refs/heads/main
remote_main=$(git ls-remote origin refs/heads/main | awk '{print $1}')
[[ $remote_main == "$candidate" ]] || fail 'remote main does not match candidate after push'

printf 'https://github.com/%s/commit/%s\n' "$REPOSITORY" "$candidate"
