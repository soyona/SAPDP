#!/usr/bin/env bash

set -euo pipefail

readonly EXPECTED_ORIGIN="https://github.com/soyona/SAPDP"

error() {
  printf 'ERROR SAPDP_HANDOFF_%s\n' "$1" >&2
  exit 1
}

block() {
  printf 'BLOCKED SAPDP_HANDOFF_%s\n' "$1" >&2
  exit 1
}

rfc3986_encode() {
  local input=$1 output= character hex index
  LC_ALL=C
  for ((index = 0; index < ${#input}; index++)); do
    character=${input:index:1}
    case $character in
      [a-zA-Z0-9.~_-]) output+=$character ;;
      *)
        printf -v hex '%%%02X' "'$character"
        output+=$hex
        ;;
    esac
  done
  printf '%s' "$output"
}

validate_scalar_inputs() {
  [[ $source_stage =~ ^(design-freeze|materialization)$ ]] \
    || error ARGUMENT_INVALID
  [[ $target_stage =~ ^(materialization|repository-audit)$ ]] \
    || error ARGUMENT_INVALID
  [[ $protocol_ref =~ ^[0-9a-f]{40}$ ]] || error ARGUMENT_INVALID
  [[ $freeze_digest =~ ^sha256:[0-9a-f]{64}$ ]] || error ARGUMENT_INVALID
  [[ -n $freeze_file && $freeze_file != /* && $freeze_file != *'..'* \
    && $freeze_file != .git/* ]] || error ARGUMENT_INVALID

  if [[ $source_stage == design-freeze && $target_stage == materialization ]]; then
    [[ -z $candidate_commit ]] || error TRANSITION_INVALID
    stage=5
    expected_task='Execute Protocol Evolution Materialization from the validated Design Freeze.'
    expected_output='Commit URL only; then emit the Repository Audit Handoff Card outside script stdout.'
  elif [[ $source_stage == materialization && $target_stage == repository-audit ]]; then
    [[ $candidate_commit =~ ^[0-9a-f]{40}$ ]] || error TRANSITION_INVALID
    stage=6
    expected_task='Execute Protocol Evolution Repository Audit for the validated Candidate Commit.'
    expected_output='Repository Audit Result contract; PASS continues directly to Release in this thread.'
  else
    error TRANSITION_INVALID
  fi
}

validate_repository() {
  local root_document declared calculated remote_main

  [[ $origin_url == "$EXPECTED_ORIGIN" ]] || block ORIGIN_MISMATCH
  git cat-file -e "${protocol_ref}^{commit}" 2>/dev/null || block REF_UNAVAILABLE

  root_document=$(git show "${protocol_ref}:SAPDP.md" 2>/dev/null) \
    || block ROOT_AUTHORITY_INVALID
  [[ $(grep -c '^authority_registry_location=SAPDP.md$' <<<"$root_document") -eq 1 ]] \
    || block ROOT_AUTHORITY_INVALID
  [[ $(grep -c '^<!-- Authority Registry Start -->$' <<<"$root_document") -eq 1 \
    && $(grep -c '^<!-- Authority Registry End -->$' <<<"$root_document") -eq 1 ]] \
    || block ROOT_AUTHORITY_INVALID

  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || block WORKSPACE_UNAVAILABLE
  cd "$repo_root"
  [[ $(git branch --show-current) == main ]] || block BRANCH_MISMATCH
  [[ $(git rev-parse HEAD) == "$protocol_ref" ]] || block HEAD_MISMATCH

  remote_main=$(sapdp_remote_ref origin refs/heads/main) \
    || block REMOTE_MAIN_UNAVAILABLE
  [[ -n $remote_main ]] || block REMOTE_MAIN_UNAVAILABLE
  [[ $remote_main == "$protocol_ref" ]] || block REMOTE_MAIN_MISMATCH

  [[ -f $freeze_file && ! -L $freeze_file ]] || block FREEZE_PATH_INVALID
  declared=$(sed -n 's/^Freeze Digest: //p' "$freeze_file")
  [[ $declared == "$freeze_digest" ]] || block FREEZE_DIGEST_MISMATCH
  calculated="sha256:$(sapdp_freeze_digest "$freeze_file")" \
    || block FREEZE_DIGEST_MISMATCH
  [[ $calculated == "$freeze_digest" ]] || block FREEZE_DIGEST_MISMATCH

  if [[ $target_stage == repository-audit ]]; then
    [[ $candidate_commit == "$protocol_ref" ]] || block CANDIDATE_INVALID
    git cat-file -e "${candidate_commit}^{commit}" 2>/dev/null \
      || block CANDIDATE_INVALID
  fi

  ./scripts/sapdp-context \
    --ref "$protocol_ref" \
    --flow protocol-evolution \
    --stage "$stage" >/dev/null 2>&1 \
    || block TARGET_AUTHORITY_INVALID
}

build_output() {
  local contract encoded_path encoded_origin encoded_prompt

  contract=$(
    printf '%s\n' \
      'SAPDP' \
      '' \
      'Upgrade SAPDP' \
      '' \
      'SAPDP_THREAD_HANDOFF_START' \
      'handoff_schema=sapdp-thread-handoff-v1' \
      "source_stage=${source_stage}" \
      "target_stage=${target_stage}" \
      "origin_url=${origin_url}" \
      "protocol_ref=${protocol_ref}" \
      "freeze_file=${freeze_file}" \
      "freeze_digest=${freeze_digest}"
    if [[ -n $candidate_commit ]]; then
      printf 'candidate_commit=%s\n' "$candidate_commit"
    fi
    printf '%s\n' \
      "task=${expected_task}" \
      "output=${expected_output}" \
      'SAPDP_THREAD_HANDOFF_END'
  ) || error RENDER_FAILED
  [[ $(LC_ALL=C printf '%s' "$contract" | wc -c | tr -d ' ') -le 2048 ]] \
    || block BUDGET_EXCEEDED

  encoded_path=$(rfc3986_encode "$repo_root") || error ENCODING_FAILED
  encoded_origin=$(rfc3986_encode "$origin_url") || error ENCODING_FAILED
  encoded_prompt=$(rfc3986_encode "$contract") || error ENCODING_FAILED
  deep_link="codex://threads/new?path=${encoded_path}&originUrl=${encoded_origin}&prompt=${encoded_prompt}"
  [[ $(LC_ALL=C printf '%s' "$deep_link" | wc -c | tr -d ' ') -le 6144 ]] \
    || block BUDGET_EXCEEDED

  card=$(
    printf 'SAPDP Protocol Evolution Handoff\n\n'
    printf 'Source: `%s`\n\n' "$source_stage"
    printf 'Target: `%s`\n\n' "$target_stage"
    printf 'Codex App: [Open %s thread](%s)\n\n' "$target_stage" "$deep_link"
    printf 'CLI: run `/new`, then paste the Prompt.\n\n'
    printf 'IDE: open New Thread, then paste the Prompt.\n\n'
    printf 'Prompt:\n\n%s\n%s\n%s\n' '```text' "$contract" '```'
  ) || error RENDER_FAILED
  [[ $(LC_ALL=C printf '%s' "$card" | wc -c | tr -d ' ') -le 8192 ]] \
    || block BUDGET_EXCEEDED
}

command=${1:-}
source_stage=
target_stage=
origin_url=
protocol_ref=
freeze_file=
freeze_digest=
candidate_commit=
provided_task=
provided_output=
stage=
expected_task=
expected_output=
repo_root=
deep_link=
card=

case $command in
  render)
    [[ $# -eq 11 || $# -eq 13 ]] || error USAGE
    [[ $2 == --source-stage && $4 == --target-stage \
      && $6 == --protocol-ref && $8 == --freeze-file \
      && ${10} == --freeze-digest ]] || error USAGE
    source_stage=$3
    target_stage=$5
    protocol_ref=$7
    freeze_file=$9
    freeze_digest=${11}
    if [[ $# -eq 13 ]]; then
      [[ ${12} == --candidate-commit ]] || error USAGE
      candidate_commit=${13}
    fi
    origin_url=$(git config --get remote.origin.url 2>/dev/null) \
      || block ORIGIN_MISMATCH
    ;;
  validate)
    [[ $# -eq 17 || $# -eq 19 ]] || error USAGE
    [[ $2 == --source-stage && $4 == --target-stage \
      && $6 == --origin-url && $8 == --protocol-ref \
      && ${10} == --freeze-file && ${12} == --freeze-digest ]] \
      || error USAGE
    source_stage=$3
    target_stage=$5
    origin_url=$7
    protocol_ref=$9
    freeze_file=${11}
    freeze_digest=${13}
    if [[ $# -eq 19 ]]; then
      [[ ${14} == --candidate-commit && ${16} == --task && ${18} == --output ]] \
        || error USAGE
      candidate_commit=${15}
      provided_task=${17}
      provided_output=${19}
    else
      [[ ${14} == --task && ${16} == --output ]] || error USAGE
      provided_task=${15}
      provided_output=${17}
    fi
    ;;
  *)
    error USAGE
    ;;
esac

# shellcheck source=scripts/lib/sapdp-validation.sh
source "$(git rev-parse --show-toplevel 2>/dev/null)/scripts/lib/sapdp-validation.sh" \
  || block WORKSPACE_UNAVAILABLE

validate_scalar_inputs
if [[ $command == validate ]]; then
  [[ $provided_task == "$expected_task" && $provided_output == "$expected_output" ]] \
    || error CONTRACT_INVALID
fi
validate_repository
build_output

if [[ $command == render ]]; then
  printf '%s\n' "$card"
else
  printf 'PASS\n'
fi
