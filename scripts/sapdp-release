#!/usr/bin/env bash

set -euo pipefail

readonly REPOSITORY="soyona/SAPDP"

fail() {
  printf 'sapdp-release: %s\n' "$1" >&2
  exit 1
}

[[ $# -eq 0 ]] || fail 'usage: sapdp-release'

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || fail 'not inside a Git repository'
cd "$repo_root"

[[ -z $(git status --porcelain) ]] || fail 'working tree is dirty'

heading=$(sed -n '1p' SAPDP.md)
if [[ $heading =~ ^#\ SAPDP\ v([0-9]+\.[0-9]+\.[0-9]+)\ Protocol$ ]]; then
  tag="v${BASH_REMATCH[1]}"
else
  fail 'invalid SAPDP.md version heading'
fi

[[ $(grep -c '^<!-- Runtime Summary Start -->$' SAPDP.md) -eq 1 ]] \
  || fail 'Runtime Summary Start marker missing or duplicated'
[[ $(grep -c '^<!-- Runtime Summary End -->$' SAPDP.md) -eq 1 ]] \
  || fail 'Runtime Summary End marker missing or duplicated'

digest_line=$(grep '^Protocol Digest:' SAPDP.md || true)
[[ $digest_line =~ ^Protocol\ Digest:\ sha256:([0-9a-f]{64})$ ]] \
  || fail 'invalid Protocol Digest'
actual_digest=${BASH_REMATCH[1]}
expected_digest=$(sed '/^Protocol Digest:/d' SAPDP.md | shasum -a 256 | awk '{print $1}')
[[ $actual_digest == "$expected_digest" ]] \
  || fail 'Protocol Digest is inconsistent'

if grep -Eiq '^Protocol Ref:[[:space:]]*[0-9a-f]{40}([[:space:]]|$)' SAPDP.md; then
  fail 'Protocol Ref must be resolved from Git, not hardcoded'
fi

git rev-parse --verify --quiet "refs/tags/${tag}" >/dev/null \
  && fail "local tag ${tag} already exists"
[[ -z $(git ls-remote --tags origin "refs/tags/${tag}" "refs/tags/${tag}^{}") ]] \
  || fail "remote tag ${tag} already exists"

git tag -a "$tag" -m "SAPDP ${tag}" HEAD
git push --quiet origin "refs/tags/${tag}"

printf 'https://github.com/%s/tree/%s\n' "$REPOSITORY" "$tag"
