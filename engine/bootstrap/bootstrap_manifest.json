{
  "manifest_version": "1.6.4",
  "protocol": "SAPDP",
  "protocol_version": "1.6.4",
  "latest_stable_version_rule": "highest_semantic_tag_in_git",
  "default_protocol_version": "latest",
  "omitted_protocol_version_behavior": "resolve_to_latest_stable_version",
  "bootstrap_version": "1.6.4",
  "bootstrap_contract_version": "1.6.4",
  "bootstrap_validation_contract_version": "1.6.4",
  "authority": {
    "configuration_authority": "bootstrap/bootstrap_manifest.json",
    "execution_authority": "contracts/bootstrap/BootstrapContract.md",
    "validation_authority": "contracts/bootstrap/BootstrapValidationContract.md",
    "lifecycle_state_authority": "PROJECT_STATE.md",
    "bootstrap_metadata_authority": "PROJECT_BOOTSTRAP.md",
    "artifact_index_authority": "ARTIFACT_INDEX.md",
    "route_manifest_authority": "ROUTE_MANIFEST.md"
  },
  "required_directories": [
    "docs/problem",
    "docs/solution",
    "docs/product",
    "docs/mvp",
    "docs/tasks",
    "docs/verification",
    "docs/validation",
    "docs/release",
    "docs/protocol",
    "templates/problem",
    "templates/solution",
    "templates/product",
    "templates/mvp",
    "templates/tasks",
    "templates/verification",
    "templates/validation",
    "templates/release",
    "templates/state",
    "src",
    "tests"
  ],
  "forbidden_final_project_directories": [
    "outputs",
    "work"
  ],
  "required_files": [
    "README.md",
    "PROJECT_STATE.md",
    "PROJECT_BOOTSTRAP.md",
    "ARTIFACT_INDEX.md",
    "ROUTE_MANIFEST.md",
    "BOOTSTRAP_RESULT.md",
    "POST_BOOTSTRAP_ENTRY.md",
    "docs/protocol/SAPDP_CANONICAL_PROTOCOL.md",
    "docs/protocol/SAPDP_SOURCE_VERSION.md",
    "docs/problem/.gitkeep",
    "docs/solution/.gitkeep",
    "docs/product/.gitkeep",
    "docs/mvp/.gitkeep",
    "docs/tasks/.gitkeep",
    "docs/verification/.gitkeep",
    "docs/validation/.gitkeep",
    "docs/release/.gitkeep",
    "src/.gitkeep",
    "tests/.gitkeep"
  ],
  "required_templates": [
    "templates/problem/ProblemDefinition_Template.md",
    "templates/solution/SolutionDefinition_Template.md",
    "templates/product/ProductRequirement_Template.md",
    "templates/product/ProductRepresentation_Template.md",
    "templates/product/UXSpecification_Template.md",
    "templates/product/VisualDesignSpecification_Template.md",
    "templates/product/TechnicalConstraint_Template.md",
    "templates/mvp/MVPDefinition_Template.md",
    "templates/tasks/TaskPackage_Template.md",
    "templates/verification/ImplementationVerification_Template.md",
    "templates/validation/UserValidation_Template.md",
    "templates/release/ReleaseResult_Template.md",
    "templates/state/PROJECT_STATE_TEMPLATE.md"
  ],
  "initial_runtime": {
    "initial_lifecycle_stage": "Problem",
    "stage_status": "READY",
    "allowed_transition": "None",
    "required_next_action": "Create ProblemDefinition_CORE_v1.md",
    "state_authority": "PROJECT_STATE.md"
  },
  "protocol_snapshot": {
    "strategy": "copy_snapshot_with_source_commit_hash",
    "required_snapshot_file": "docs/protocol/SAPDP_CANONICAL_PROTOCOL.md",
    "required_source_version_file": "docs/protocol/SAPDP_SOURCE_VERSION.md",
    "forbidden_strategies": [
      "git_submodule",
      "remote_reference_only",
      "live_protocol_dependency"
    ]
  },
  "validation_rule_ids": [
    "product_repository_exists",
    "sapdp_repository_accessible",
    "project_name_resolved_before_project_root",
    "project_root_derived_from_project_name",
    "project_identity_consistent",
    "readme_exists",
    "required_directories_exist",
    "required_files_exist",
    "required_templates_exist",
    "scaffold_persistence_files_exist",
    "empty_directories_are_git_persistable",
    "lifecycle_progress_ui_format_valid",
    "forbidden_final_project_directories_absent",
    "scaffold_conforms_to_sapdp_project_scaffold",
    "project_bootstrap_exists",
    "project_state_exists",
    "artifact_index_exists",
    "bootstrap_result_exists",
    "post_bootstrap_entry_exists",
    "protocol_snapshot_exists",
    "sapdp_source_commit_hash_exists",
    "protocol_version_exists",
    "detected_protocol_version_exists",
    "latest_stable_version_exists",
    "protocol_source_exists",
    "latest_resolves_to_concrete_tag",
    "protocol_version_consistent_across_bootstrap_artifacts",
    "route_manifest_exists",
    "route_manifest_ownership_valid",
    "lifecycle_state_initialized",
    "lifecycle_ready_for_problem_stage",
    "no_lifecycle_artifact_created",
    "no_product_source_code_created",
    "no_forbidden_action_executed"
  ],
  "idempotency": {
    "bootstrap_is_idempotent": true,
    "existing_sapdp_files_protected": true,
    "overwrite_requires_confirmation": true,
    "non_empty_incomplete_repository_result": "PATCH REQUIRED",
    "preexisting_product_code_result": "FAIL",
    "preexisting_lifecycle_artifact_result": "FAIL"
  },
  "forbidden_actions": [
    "create_problem_definition_artifact",
    "create_solution_definition_artifact",
    "create_product_representation_artifact",
    "create_mvp_definition_artifact",
    "create_task_package_artifact",
    "create_build_artifact",
    "implement_product_source_code",
    "infer_product_requirements",
    "infer_target_users",
    "infer_solution_direction",
    "infer_mvp_definition",
    "modify_sapdp_repository",
    "create_second_protocol_repository",
    "rename_sapdp_protocol_files",
    "store_artifact_activation_state",
    "advance_beyond_problem_stage",
    "skip_bootstrap_validation"
  ],
  "result_files": {
    "bootstrap_result": "BOOTSTRAP_RESULT.md",
    "post_bootstrap_entry": "POST_BOOTSTRAP_ENTRY.md"
  },
  "route_manifest": {
    "required_file": "ROUTE_MANIFEST.md",
    "template": "bootstrap/ROUTE_MANIFEST_TEMPLATE.md",
    "generation_owner": "Codex",
    "consumption_owner": "ChatGPT",
    "authority_boundary": {
      "lifecycle_state_authority": "PROJECT_STATE.md",
      "bootstrap_metadata_authority": "PROJECT_BOOTSTRAP.md",
      "artifact_discovery_authority": "ARTIFACT_INDEX.md",
      "lifecycle_authority": "SAPDP_LIFECYCLE.md"
    }
  },
  "status": "Frozen"
}
